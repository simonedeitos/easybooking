Options -Indexes

# ── Rewrite engine ───────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Set this to the URL path where the webapp is installed.
    # Use / if the app is at the domain root (e.g. easybooking.vocefutura.it/).
    # Use /easybooking/ if the app is in a subdirectory (e.g. vocefutura.it/easybooking/).
    # Public share links can still point somewhere else via CLOUD_PUBLIC_BASE_URL in webapp/.env.
    RewriteBase /

    # /share/[HASH] → cloud_pubblica.php?hash=[HASH]
    RewriteRule ^share/([a-f0-9]{32})/?$ cloud_pubblica.php?hash=$1 [QSA,L]

    # /share/[HASH]/download/[FILE_ID]
    RewriteRule ^share/([a-f0-9]{32})/download/([0-9]+)/?$ cloud_pubblica.php?hash=$1&action=download&file_id=$2 [QSA,L]

    # /share/[HASH]/stream/[FILE_ID]
    RewriteRule ^share/([a-f0-9]{32})/stream/([0-9]+)/?$ cloud_pubblica.php?hash=$1&action=stream&file_id=$2 [QSA,L]
</IfModule>
