# EasyBooking – Environment Configuration Template
# Copy this file to .env and fill in your values.
# The .env file is loaded by webapp/config/database.php.

# ── Database ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=easybooking
DB_USER=easybooking
DB_PASS=change_me

# ── Cloud Storage ─────────────────────────────────────────────────────────
# Absolute path to the cloud storage directory.
# Must be OUTSIDE the web root so files are not directly accessible via HTTP.
# Set this explicitly in production when the auto-detected path is not correct.
# Example: CLOUD_STORAGE_PATH=/var/www/cloud_storage
# CLOUD_STORAGE_PATH=/var/www/cloud_storage

# Public base URL used to build share links.
# Required when the admin panel runs on a subdomain but public share links must
# open on the main public domain (example: admin on easybooking.vocefutura.it,
# public links on vocefutura.it/share/[HASH]).
# CLOUD_PUBLIC_BASE_URL=https://vocefutura.it

# Optional fallback for public_html/index_cloud.php when auto-discovery of
# webapp/config/database.php fails on shared hosting layouts such as Hostinger.
# Use an absolute filesystem path to webapp/config/database.php.
# EASYBOOKING_CONFIG_PATH=/home/your-user/public_html/easybooking/webapp/config/database.php
