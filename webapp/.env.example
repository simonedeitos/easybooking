# EasyBooking – Environment Configuration Template
# Copy this file to .env and fill in your values.
# The .env file is loaded by webapp/config/database.php.

# ── Database ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=easybooking
DB_USER=easybooking
DB_PASS=change_me

# ── Cron Security ─────────────────────────────────────────────────────────
# Secret token required to invoke cron scripts via HTTP.
# Generate a long random string (e.g.: openssl rand -hex 32).
# Leave empty to block all HTTP access to cron scripts (only CLI allowed).
# CRON_SECRET=replace_with_a_long_random_secret

# ── Cloud Storage ─────────────────────────────────────────────────────────
# Absolute path to the cloud storage directory.
# Must be OUTSIDE the web root so files are not directly accessible via HTTP.
# Default (if unset): <repo-root>/cloud_storage
# CLOUD_STORAGE_PATH=/var/www/cloud_storage

# Public base URL used to build share links.
# IMPORTANT: if admin panel runs on a subdomain (e.g. easybooking.vocefutura.it)
# but public /share/... pages are on the main domain (e.g. vocefutura.it),
# this value is REQUIRED and MUST point to the main public domain.
# Without this explicit value, automatic host detection will use the current
# host (often the admin subdomain) and generated share links will be wrong.
# Set this when auto-detection fails, e.g. behind a reverse proxy.
# Include the scheme and host; include the subdirectory if the app is not at root.
# Examples:
#   CLOUD_PUBLIC_BASE_URL=https://yourdomain.com
#   CLOUD_PUBLIC_BASE_URL=https://yourdomain.com/easybooking
#   CLOUD_PUBLIC_BASE_URL=https://vocefutura.it
CLOUD_PUBLIC_BASE_URL=https://yourdomain.com
