# EasyBooking – Environment Configuration Template
# Copy this file to .env and fill in your values.
# The .env file is loaded by webapp/config/database.php.

# ── Database ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=easybooking
DB_USER=easybooking
DB_PASS=change_me

# ── Cloud Storage ─────────────────────────────────────────────────────────
# Absolute path to the cloud storage directory.
# Must be OUTSIDE the web root so files are not directly accessible via HTTP.
# Default (if unset): <repo-root>/cloud_storage
# CLOUD_STORAGE_PATH=/var/www/cloud_storage

# Public base URL used to build share links.
# Set this when auto-detection fails, e.g. behind a reverse proxy.
# Include the scheme and host; include the subdirectory if the app is not at root.
# Examples:
#   CLOUD_PUBLIC_BASE_URL=https://yourdomain.com
#   CLOUD_PUBLIC_BASE_URL=https://yourdomain.com/easybooking
# CLOUD_PUBLIC_BASE_URL=https://yourdomain.com
